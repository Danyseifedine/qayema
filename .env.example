APP_NAME=Laravel
# PRODUCTION: set APP_ENV=production and APP_DEBUG=false. Debug mode leaks stack
# traces (env vars, DB credentials); APP_ENV must not be "local" in production
# (Telescope only loads in local). These local defaults are for development only.
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=menux
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
# Leading-dot root domain so the session cookie is shared with the dashboard
# subdomain SPA (e.g. SESSION_DOMAIN=.qayema.com). Leave null for a single host.
SESSION_DOMAIN=null
# Only send the session cookie over HTTPS (keep true in production)
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# --- Dashboard SPA (Sanctum cookie-based auth) ---
# Hosts allowed to make stateful (cookie-authenticated) requests (no scheme/port-less host).
SANCTUM_STATEFUL_DOMAINS=dashboard.qayema.com
# Cross-origin browser origins permitted to send credentialed requests (full origin, comma-separated).
CORS_ALLOWED_ORIGINS=https://dashboard.qayema.com
# Absolute URL the onboarding wizard redirects to once setup completes.
DASHBOARD_URL=https://dashboard.qayema.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_RECIPIENT_EMAIL="hello@example.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Trusted reverse proxies (comma-separated IPs/CIDRs, or * to trust all). Leave empty when not behind a proxy.
TRUSTED_PROXIES=

# IPs AbuseGuard never rate-bans or blocks (comma-separated) — e.g. office / monitoring egress IPs.
SECURITY_TRUSTED_IPS=

# Google reCAPTCHA v3. Leave both empty to disable captcha entirely (graceful no-op).
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=

VITE_APP_NAME="${APP_NAME}"
